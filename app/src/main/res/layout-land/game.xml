<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape variant of the game layout.
  IMPORTANT: every view ID must match layout/game.xml exactly —
  GameActivity.bindViews() casts by type (e.g. foundation* must be ImageView,
  btnUndo must be present) and crashes with ClassCastException / NPE otherwise.
  Changes from portrait: card height 72dp, stockArea 46×72dp.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gameRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar: timer + difficulty badge -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textSize="16sp"
            android:textColor="@color/casino_gold"
            android:fontFamily="monospace"
            android:contentDescription="Timer di gioco"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟡 Normale"
            android:textSize="13sp"
            android:textColor="@color/casino_gold_light"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            tools:ignore="HardcodedText" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pause"
            android:tint="@color/casino_gold"
            android:background="@android:color/transparent"
            android:contentDescription="@string/pause_menu_desc" />
    </LinearLayout>

    <!-- Foundations row (4 slots) — must be ImageView, not FrameLayout -->
    <LinearLayout
        android:id="@+id/foundationsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView android:id="@+id/foundation0"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="72dp" android:layout_marginHorizontal="4dp"
            android:minWidth="48dp" android:minHeight="48dp"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:background="@drawable/casino_slot_frame"
            android:src="@drawable/zero"
            android:clickable="true" android:focusable="true"
            android:contentDescription="@string/foundation_empty_desc" />

        <ImageView android:id="@+id/foundation1"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="72dp" android:layout_marginHorizontal="4dp"
            android:minWidth="48dp" android:minHeight="48dp"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:background="@drawable/casino_slot_frame"
            android:src="@drawable/zero"
            android:clickable="true" android:focusable="true"
            android:contentDescription="@string/foundation_empty_desc" />

        <ImageView android:id="@+id/foundation2"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="72dp" android:layout_marginHorizontal="4dp"
            android:minWidth="48dp" android:minHeight="48dp"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:background="@drawable/casino_slot_frame"
            android:src="@drawable/zero"
            android:clickable="true" android:focusable="true"
            android:contentDescription="@string/foundation_empty_desc" />

        <ImageView android:id="@+id/foundation3"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="72dp" android:layout_marginHorizontal="4dp"
            android:minWidth="48dp" android:minHeight="48dp"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:background="@drawable/casino_slot_frame"
            android:src="@drawable/zero"
            android:clickable="true" android:focusable="true"
            android:contentDescription="@string/foundation_empty_desc" />
    </LinearLayout>

    <!-- 4 pile columns -->
    <LinearLayout
        android:id="@+id/pilesArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/foundationsRow"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView android:id="@+id/pileScroll0"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">
            <LinearLayout android:id="@+id/pileContainer0"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp" />
        </ScrollView>

        <ScrollView android:id="@+id/pileScroll1"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">
            <LinearLayout android:id="@+id/pileContainer1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp" />
        </ScrollView>

        <ScrollView android:id="@+id/pileScroll2"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">
            <LinearLayout android:id="@+id/pileContainer2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp" />
        </ScrollView>

        <ScrollView android:id="@+id/pileScroll3"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">
            <LinearLayout android:id="@+id/pileContainer3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp" />
        </ScrollView>
    </LinearLayout>

    <!-- Tutorial overlay (hidden by default) -->
    <LinearLayout
        android:id="@+id/tutorialOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTutorialInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <Button
            android:id="@+id/btnTutorialNext"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:text="@string/tutorial_next"
            android:textColor="@color/casino_gold"
            android:backgroundTint="@color/casino_bordeaux_dark"
            android:minWidth="48dp"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- Bottom bar: stock + redeal + hint + undo -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Stock (tallone) -->
        <FrameLayout
            android:id="@+id/stockArea"
            android:layout_width="46dp"
            android:layout_height="72dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Tallone — tocca per distribuire">

            <ImageView
                android:id="@+id/stockImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="Dorso carta" />

            <TextView
                android:id="@+id/tvStockCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:textSize="11sp"
                android:padding="2dp"
                android:background="#88000000"
                android:textColor="#FFFFFF" />
        </FrameLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Redeal button -->
        <Button
            android:id="@+id/btnRedeal"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/redeal_button"
            android:textSize="13sp"
            android:textColor="@color/casino_gold"
            android:backgroundTint="@color/casino_bordeaux_dark"
            android:visibility="gone"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:layout_marginEnd="8dp" />

        <!-- Redeals remaining label -->
        <TextView
            android:id="@+id/tvRedealsLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/casino_gold_light"
            android:layout_marginEnd="8dp" />

        <!-- Undo button — required by GameActivity.renderBottomBar() -->
        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/undo_button"
            android:textSize="18sp"
            android:textColor="@color/casino_gold"
            android:backgroundTint="@color/casino_bordeaux_dark"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:layout_marginEnd="8dp" />

        <!-- Hint button -->
        <Button
            android:id="@+id/btnHint"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/hint_button"
            android:textSize="18sp"
            android:textColor="@color/casino_gold"
            android:backgroundTint="@color/casino_bordeaux_dark"
            android:minWidth="48dp"
            android:minHeight="48dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
