<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/deckItemRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/casino_tile_bg"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/deckLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:textStyle="italic|bold"
        android:textColor="@color/casino_gold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/deckPreview1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="90dp"
            android:scaleType="centerInside"
            android:layout_marginHorizontal="4dp" />

        <ImageView
            android:id="@+id/deckPreview2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="90dp"
            android:scaleType="centerInside"
            android:layout_marginHorizontal="4dp" />

        <ImageView
            android:id="@+id/deckPreview3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="90dp"
            android:scaleType="centerInside"
            android:layout_marginHorizontal="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/deckComingSoonLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/card_type_coming_soon"
        android:textSize="12sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:textColor="@color/casino_gold_alpha_50"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

</LinearLayout>
