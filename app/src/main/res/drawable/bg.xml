<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bordeaux base -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/casino_bordeaux"
                android:endColor="@color/casino_bordeaux_dark" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Outer gold frame -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="@color/casino_gold" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Inner gold frame -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/casino_gold_dark" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <!-- Central diamond medallion - outer -->
    <item android:left="20dp" android:top="40dp" android:right="20dp" android:bottom="40dp">
        <rotate android:fromDegrees="45" android:toDegrees="45" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="rectangle">
                <stroke android:width="2dp" android:color="@color/casino_gold" />
                <solid android:color="@android:color/transparent" />
            </shape>
        </rotate>
    </item>
    <!-- Central diamond medallion - inner -->
    <item android:left="28dp" android:top="48dp" android:right="28dp" android:bottom="48dp">
        <rotate android:fromDegrees="45" android:toDegrees="45" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="rectangle">
                <stroke android:width="1dp" android:color="@color/casino_gold_light" />
                <solid android:color="@android:color/transparent" />
            </shape>
        </rotate>
    </item>
</layer-list>
