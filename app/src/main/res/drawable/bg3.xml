<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ink/black base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/casino_ink"
                android:endColor="#FF050505" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Outer gold thick frame -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2.5dp" android:color="@color/casino_gold" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Inner gold frame -->
    <item android:left="7dp" android:top="7dp" android:right="7dp" android:bottom="7dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="@color/casino_gold_light" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <!-- Central ornate medallion - outer oval (gold ring) -->
    <item android:left="22dp" android:top="46dp" android:right="22dp" android:bottom="46dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/casino_gold" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Central inner oval (thin) -->
    <item android:left="28dp" android:top="52dp" android:right="28dp" android:bottom="52dp">
        <shape android:shape="oval">
            <stroke android:width="0.5dp" android:color="@color/casino_gold_light" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Tiny central gold dot -->
    <item android:left="42dp" android:top="66dp" android:right="42dp" android:bottom="66dp">
        <shape android:shape="oval">
            <solid android:color="@color/casino_gold" />
        </shape>
    </item>
</layer-list>
